# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend API
API_PORT=4000
ALLOWED_ORIGIN="http://localhost:3000"
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/db_name?retryWrites=true&w=majority"
JWT_SECRET="replace-with-a-long-random-secret"
NOTE_MAX_FILE_MB=20

# Frontend Web3 config
VITE_API_URL="http://localhost:4000"
VITE_TOKEN_ADDRESS=""
VITE_CHAIN_ID=80002

# Optional chain info (used when asking MetaMask to add/switch chain)
VITE_CHAIN_NAME="Polygon Amoy"
VITE_CHAIN_RPC_URL="https://rpc-amoy.polygon.technology/"
VITE_CHAIN_CURRENCY_SYMBOL="POL"
VITE_CHAIN_BLOCK_EXPLORER="https://amoy.polygonscan.com"

# Deployment keys (never commit real secrets)
PRIVATE_KEY=""
SEPOLIA_RPC_URL=""
BSC_TESTNET_RPC_URL=""
POLYGON_AMOY_RPC_URL=""
